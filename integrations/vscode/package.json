{
  "name": "luna-ai",
  "displayName": "Luna AI",
  "description": "Luna AI assistant — chat, code explain, fix, and search directly in VS Code",
  "version": "0.0.1",
  "publisher": "luna",
  "engines": { "vscode": "^1.94.0" },
  "categories": ["AI", "Other"],
  "icon": "media/luna-icon.png",
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "luna.openChat",
        "title": "Open Chat",
        "category": "Luna"
      },
      {
        "command": "luna.askAboutSelection",
        "title": "Ask Luna About This",
        "category": "Luna"
      },
      {
        "command": "luna.explainCode",
        "title": "Explain This Code",
        "category": "Luna"
      },
      {
        "command": "luna.fixCode",
        "title": "Fix This Code",
        "category": "Luna"
      },
      {
        "command": "luna.newChat",
        "title": "New Conversation",
        "category": "Luna"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "luna-sidebar-secondary",
          "title": "Luna AI",
          "icon": "media/luna-icon.svg"
        }
      ]
    },
    "views": {
      "luna-sidebar-secondary": [
        {
          "type": "webview",
          "id": "luna.chatViewSecondary",
          "name": "Luna AI"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "luna.explainCode",
          "when": "editorHasSelection",
          "group": "luna@1"
        },
        {
          "command": "luna.fixCode",
          "when": "editorHasSelection",
          "group": "luna@2"
        },
        {
          "command": "luna.askAboutSelection",
          "when": "editorHasSelection",
          "group": "luna@3"
        }
      ],
      "commandPalette": [
        { "command": "luna.openChat" },
        { "command": "luna.newChat" },
        { "command": "luna.askAboutSelection", "when": "editorHasSelection" },
        { "command": "luna.explainCode", "when": "editorHasSelection" },
        { "command": "luna.fixCode", "when": "editorHasSelection" }
      ]
    },
    "keybindings": [
      {
        "command": "luna.openChat",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "luna.askAboutSelection",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Luna AI",
      "properties": {
        "luna.backendUrl": {
          "type": "string",
          "default": "http://localhost:8765",
          "description": "Luna backend URL (must be running locally)"
        },
        "luna.streamingEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Stream tokens as they arrive"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
