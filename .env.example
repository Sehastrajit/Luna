app_name=L.U.N.A.
host=127.0.0.1
port=8899
debug=false

# ── LLM provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai-compatible | anthropic | google | groq | cohere | mistral
llm_provider=ollama

# Ollama (local, default — no API key, no internet)
ollama_base_url=http://localhost:11434
ollama_model=qwen2.5:7b
ollama_embed_model=nomic-embed-text

# OpenAI / OpenAI-compatible (OpenRouter, LM Studio, Jan.ai, llama.cpp, etc.)
# llm_provider=openai-compatible
openai_base_url=https://api.openai.com/v1
openai_api_key=
openai_model=gpt-4o-mini
openai_embed_model=text-embedding-3-small
embedding_provider=ollama

# Anthropic Claude (native — fastest for Claude models)
# llm_provider=anthropic
anthropic_api_key=
anthropic_model=claude-sonnet-4-5

# Google Gemini (native)
# llm_provider=google
google_api_key=
google_model=gemini-2.0-flash

# Groq (native — ~300 tok/s cloud inference, free tier available)
# llm_provider=groq
groq_api_key=
groq_model=llama-3.3-70b-versatile

# Cohere Command R (native)
# llm_provider=cohere
cohere_api_key=
cohere_model=command-r-plus

# Mistral AI (native)
# llm_provider=mistral
mistral_api_key=
mistral_model=mistral-large-latest

# ── Auth & access ─────────────────────────────────────────────────────────────
# Shared API key — set any strong random string to enable auth on all /api/* routes.
# Leave empty for local-only dev (no auth required).
luna_api_key=

# JWT secret — required for the admin user management API (/api/admin/users).
# Generate: openssl rand -hex 32
jwt_secret=
jwt_expiry_hours=720

# ── Rate limiting (production) ────────────────────────────────────────────────
rate_limit_enabled=false
rate_limit_per_minute=60
rate_limit_burst=20

# ── Messaging channels ────────────────────────────────────────────────────────
# Telegram: get your token from @BotFather, then set the webhook:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://YOUR_HOST/api/channels/telegram"
telegram_bot_token=

# Discord: create an app at discord.com/developers, set the Interactions Endpoint URL to
#   https://YOUR_HOST/api/channels/discord
discord_bot_token=
discord_public_key=

# Slack: create a Slack App, enable Events API, set Request URL to
#   https://YOUR_HOST/api/channels/slack  and subscribe to  message.channels
slack_bot_token=
slack_signing_secret=

# ── Live data APIs ────────────────────────────────────────────────────────────
the_news_api=
alpha_vantage=
open_weather=

# Weather / dashboard location
weather_lat=40.7128
weather_lon=-74.0060
weather_city=New York
weather_timezone=America/New_York

# Spotify (opt-in — desktop only)
# spotify_client_id=
# spotify_client_secret=

# ── Persona ───────────────────────────────────────────────────────────────────
luna_name=L.U.N.A.
user_name=friend
