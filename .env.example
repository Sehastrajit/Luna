app_name=L.U.N.A.
host=127.0.0.1
port=8899
debug=false

# LLM provider: ollama or openai-compatible
llm_provider=ollama

# Local Ollama
ollama_base_url=http://localhost:11434
ollama_model=qcwind/qwen3-8b-instruct-Q4-K-M:latest
ollama_embed_model=nomic-embed-text

# OpenAI-compatible cloud/local APIs
openai_base_url=https://api.openai.com/v1
openai_api_key=
openai_model=gpt-4o-mini
openai_embed_model=text-embedding-3-small
embedding_provider=ollama

# Set a strong random value before exposing the app outside localhost.
luna_api_key=

# Optional external providers
the_news_api=
alpha_vantage=
open_weather=

# Default weather/dashboard location. Change this for your city.
weather_lat=40.7128
weather_lon=-74.0060
weather_city=New York
weather_timezone=America/New_York

# Persona defaults
luna_name=L.U.N.A.
user_name=friend
