app_name=L.U.N.A.
host=127.0.0.1
port=8899
debug=false

# ── LLM provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai-compatible | nvidia-nim | anthropic | google | groq | cohere | mistral
llm_provider=ollama

# Ollama (local, default — no API key, no internet)
ollama_base_url=http://localhost:11434
ollama_model=qwen2.5:7b
ollama_embed_model=nomic-embed-text

# OpenAI / OpenAI-compatible (OpenRouter, LM Studio, Jan.ai, llama.cpp, etc.)
# llm_provider=openai-compatible
openai_base_url=https://api.openai.com/v1
openai_api_key=
openai_model=gpt-4o-mini
openai_embed_model=text-embedding-3-small
embedding_provider=ollama

# NVIDIA NIM / NVIDIA API Catalog (OpenAI-compatible)
# llm_provider=nvidia-nim
nvidia_nim_base_url=https://integrate.api.nvidia.com/v1
nvidia_nim_api_key=
nvidia_nim_model=meta/llama-3.1-8b-instruct

# Anthropic Claude (native — fastest for Claude models)
# llm_provider=anthropic
anthropic_api_key=
anthropic_model=claude-sonnet-4-5

# Google Gemini (native)
# llm_provider=google
google_api_key=
google_model=gemini-2.0-flash

# Groq (native — ~300 tok/s cloud inference, free tier available)
# llm_provider=groq
groq_api_key=
groq_model=llama-3.3-70b-versatile

# Cohere Command R (native)
# llm_provider=cohere
cohere_api_key=
cohere_model=command-r-plus

# Mistral AI (native)
# llm_provider=mistral
mistral_api_key=
mistral_model=mistral-large-latest

# ── Auth & access ─────────────────────────────────────────────────────────────
# JWT secret — required for the Business variant admin API (/api/admin/users).
# Generate: openssl rand -hex 32
# Admin requests use: Authorization: Bearer <jwt_secret>
jwt_secret=
jwt_expiry_hours=720

# ── Rate limiting (production) ────────────────────────────────────────────────
rate_limit_enabled=false
rate_limit_per_minute=60
rate_limit_burst=20

# ── Messaging channels ────────────────────────────────────────────────────────
# Telegram: get your token from @BotFather, then set the webhook:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://YOUR_HOST/api/channels/telegram"
telegram_bot_token=

# Discord: create an app at discord.com/developers, set the Interactions Endpoint URL to
#   https://YOUR_HOST/api/channels/discord
discord_bot_token=
discord_public_key=

# Slack: create a Slack App, enable Events API, set Request URL to
#   https://YOUR_HOST/api/channels/slack  and subscribe to  message.channels
slack_bot_token=
slack_signing_secret=

# ── Workspace APIs (optional OAuth access tokens) ─────────────────────────────
google_workspace_client_id=
google_workspace_client_secret=
google_workspace_refresh_token=
google_workspace_access_token=
microsoft_workspace_client_id=
microsoft_workspace_client_secret=
microsoft_workspace_tenant_id=common
microsoft_workspace_refresh_token=
microsoft_workspace_access_token=

# ── Live data APIs ────────────────────────────────────────────────────────────
the_news_api=
alpha_vantage=
open_weather=

# Weather / dashboard location
weather_lat=40.7128
weather_lon=-74.0060
weather_city=New York
weather_timezone=America/New_York

# Spotify (opt-in — desktop only)
# 1. https://developer.spotify.com/dashboard → Create app
# 2. Redirect URI: http://127.0.0.1:8899/api/spotify/callback
# 3. After filling in below, open: http://localhost:8899/api/spotify/login
spotify_client_id=
spotify_client_secret=

# ── Health Platforms (all optional, all opt-in) ───────────────────────────────
# Fitbit — app.fitbit.com/oauth2/applications (OAuth2)
# After creating the app, start the auth flow: GET /api/health/oauth/authorize/fitbit
fitbit_client_id=
fitbit_client_secret=
fitbit_access_token=
fitbit_refresh_token=

# Google Fit — console.cloud.google.com -> enable Fitness API (OAuth2)
# After creating credentials: GET /api/health/oauth/authorize/google_fit
google_fit_client_id=
google_fit_client_secret=
google_fit_access_token=
google_fit_refresh_token=

# Oura Ring — cloud.ouraring.com/user/api-tokens (Personal Access Token)
oura_api_key=

# Withings — developer.withings.com -> create app (OAuth2)
# After creating the app: GET /api/health/oauth/authorize/withings
withings_client_id=
withings_client_secret=
withings_access_token=
withings_refresh_token=

# Garmin Connect (uses Garmin account credentials via the garth library)
# Requires: pip install garth
garmin_email=
garmin_password=

# Apple Health — no REST API; use the "Health Auto Export" iOS app
# Configure it to POST to: {luna_url}/api/health/webhook/apple
# Samsung Health — no REST API; use a compatible Android exporter app
# Configure it to POST to: {luna_url}/api/health/webhook/samsung
# Set a shared secret to authenticate inbound webhook requests:
health_webhook_secret=

# ── Persona ───────────────────────────────────────────────────────────────────
luna_name=L.U.N.A.
user_name=friend
