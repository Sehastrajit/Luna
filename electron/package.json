{
  "name": "luna",
  "version": "0.1.0",
  "description": "L.U.N.A. - Large Unified Nexus Mind AI",
  "author": "L.U.N.A. contributors",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "32.3.3",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.luna.companion",
    "productName": "Luna",
    "copyright": "Copyright (c) 2026 L.U.N.A. contributors",
    "directories": {
      "buildResources": "assets",
      "output": "../dist-electron"
    },
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "publish": [
      {
        "provider": "github",
        "owner": "Sehastrajit",
        "repo": "Luna"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "settings.js",
      "settingsPreload.js",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      },
      {
        "from": "../dist-backend/luna-backend",
        "to": "backend-bin",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "artifactName": "Luna-Setup-${version}.${ext}",
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "uninstallDisplayName": "L.U.N.A.",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  }
}
