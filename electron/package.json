{
  "name": "luna",
  "version": "1.0.0",
  "description": "L.U.N.A. - Large Unified Nexus Mind AI",
  "author": "L.U.N.A. contributors",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "32.3.3",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.luna.companion",
    "productName": "L.U.N.A.",
    "copyright": "Copyright (c) 2026 L.U.N.A. contributors",
    "directories": {
      "buildResources": "assets",
      "output": "../dist-electron"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!__pycache__/**",
          "!*.pyc"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "uninstallDisplayName": "L.U.N.A.",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  }
}
