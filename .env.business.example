# ════════════════════════════════════════════════════════════════════
#  L.U.N.A. — Business variant
#  Copy to .env:  cp .env.business.example .env
#
#  Key differences from personal:
#    - Professional tone, no personal banter or Spotify
#    - Rate limiting on by default
#    - JWT auth for per-user tokens (/api/admin/users)
#    - Slack / Telegram / Discord channels for team messaging
#    - Multi-user: each JWT user gets isolated conversation history
# ════════════════════════════════════════════════════════════════════

# Variant
luna_variant=business

app_name=L.U.N.A. Business
host=0.0.0.0
port=8899
debug=false

# ── Company identity ───────────────────────────────────────────────
business_name=Acme Corp
business_description=a technology company focused on developer productivity
# professional | friendly | technical | concise
business_tone=professional

# ── LLM provider ──────────────────────────────────────────────────
# Anthropic and Groq are recommended for business — fast, reliable, SOTA.
# Options: ollama | openai-compatible | nvidia-nim | anthropic | google | groq | cohere | mistral
llm_provider=anthropic

ollama_base_url=http://localhost:11434
ollama_model=qwen2.5:14b
ollama_embed_model=nomic-embed-text

openai_base_url=https://api.openai.com/v1
openai_api_key=
openai_model=gpt-4o

nvidia_nim_base_url=https://integrate.api.nvidia.com/v1
nvidia_nim_api_key=
nvidia_nim_model=meta/llama-3.1-8b-instruct

anthropic_api_key=sk-ant-...
anthropic_model=claude-sonnet-4-5

google_api_key=
google_model=gemini-2.0-flash

groq_api_key=
groq_model=llama-3.3-70b-versatile

cohere_api_key=
cohere_model=command-r-plus

mistral_api_key=
mistral_model=mistral-large-latest

# ── Auth ──────────────────────────────────────────────────────────
# JWT secret — required for the admin API and per-user token management.
# Admin API calls use: Authorization: Bearer <jwt_secret>
# Generate: openssl rand -hex 32
jwt_secret=CHANGE_THIS_TO_A_STRONG_RANDOM_KEY
jwt_expiry_hours=720

# ── Rate limiting ─────────────────────────────────────────────────
rate_limit_enabled=true
rate_limit_per_minute=60
rate_limit_burst=20

# ── Messaging channels ────────────────────────────────────────────
# Telegram: @BotFather → /newbot → set token here, then:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://YOUR_HOST/api/channels/telegram"
telegram_bot_token=

# Discord: discord.com/developers → New Application → Bot → copy token
#   Set Interactions Endpoint URL to: https://YOUR_HOST/api/channels/discord
discord_bot_token=
discord_public_key=

# Slack: api.slack.com/apps → Events API → Request URL: https://YOUR_HOST/api/channels/slack
#   Subscribe to: message.channels, message.im, app_mention
slack_bot_token=xoxb-...
slack_signing_secret=

# ── Persona ────────────────────────────────────────────────────────
luna_name=Assistant
user_name=team

# ── Weather / dashboard ───────────────────────────────────────────
weather_lat=40.7128
weather_lon=-74.0060
weather_city=New York
weather_timezone=America/New_York

# ── Workspace APIs (optional OAuth access tokens) ─────────────────
google_workspace_client_id=
google_workspace_client_secret=
google_workspace_refresh_token=
google_workspace_access_token=
microsoft_workspace_client_id=
microsoft_workspace_client_secret=
microsoft_workspace_tenant_id=common
microsoft_workspace_refresh_token=
microsoft_workspace_access_token=

# ── Live data APIs ────────────────────────────────────────────────
the_news_api=
alpha_vantage=
