# ════════════════════════════════════════════════════════════════════
#  L.U.N.A. — Personal variant
#  Copy to .env:  cp .env.personal.example .env
# ════════════════════════════════════════════════════════════════════

# Variant (do not change for personal use)
luna_variant=personal

app_name=L.U.N.A.
host=127.0.0.1
port=8899
debug=false

# ── LLM provider ──────────────────────────────────────────────────
# Change llm_provider and fill in the matching key block below.
# Options: ollama | openai-compatible | nvidia-nim | anthropic | google | groq | cohere | mistral
llm_provider=ollama

ollama_base_url=http://localhost:11434
ollama_model=qwen2.5:7b
ollama_embed_model=nomic-embed-text

# openai_base_url=https://api.openai.com/v1
# openai_api_key=sk-...
# openai_model=gpt-4o-mini

# nvidia_nim_base_url=https://integrate.api.nvidia.com/v1
# nvidia_nim_api_key=nvapi-...
# nvidia_nim_model=meta/llama-3.1-8b-instruct

# anthropic_api_key=sk-ant-...
# anthropic_model=claude-sonnet-4-5

# google_api_key=AIza...
# google_model=gemini-2.0-flash

# groq_api_key=gsk_...
# groq_model=llama-3.3-70b-versatile

# cohere_api_key=...
# cohere_model=command-r-plus

# mistral_api_key=...
# mistral_model=mistral-large-latest

# ── Auth ──────────────────────────────────────────────────────────
jwt_secret=
jwt_expiry_hours=720

# ── Rate limiting (off for personal use) ──────────────────────────
rate_limit_enabled=false
rate_limit_per_minute=60
rate_limit_burst=20

# ── Persona ────────────────────────────────────────────────────────
luna_name=L.U.N.A.
user_name=friend

# ── Channels (optional — for messaging apps) ───────────────────────
telegram_bot_token=
discord_bot_token=
discord_public_key=
slack_bot_token=
slack_signing_secret=

# ── Spotify (optional) ────────────────────────────────────────────
# 1. Go to https://developer.spotify.com/dashboard → Create app
# 2. Set Redirect URI to: http://127.0.0.1:8899/api/spotify/callback
# 3. Copy Client ID and Client Secret below, then run: luna open http://localhost:8899/api/spotify/login
spotify_client_id=
spotify_client_secret=

# ── Weather / dashboard ───────────────────────────────────────────
weather_lat=40.7128
weather_lon=-74.0060
weather_city=New York
weather_timezone=America/New_York

# ── Workspace APIs (optional OAuth access tokens) ─────────────────
google_workspace_client_id=
google_workspace_client_secret=
google_workspace_refresh_token=
google_workspace_access_token=
microsoft_workspace_client_id=
microsoft_workspace_client_secret=
microsoft_workspace_tenant_id=common
microsoft_workspace_refresh_token=
microsoft_workspace_access_token=

# ── Health Platforms (all optional, all opt-in) ───────────────────
# Fitbit — app.fitbit.com/oauth2/applications (OAuth2)
# After creating the app: GET /api/health/oauth/authorize/fitbit
fitbit_client_id=
fitbit_client_secret=
fitbit_access_token=
fitbit_refresh_token=

# Google Fit — console.cloud.google.com -> Fitness API (OAuth2)
# After creating credentials: GET /api/health/oauth/authorize/google_fit
google_fit_client_id=
google_fit_client_secret=
google_fit_access_token=
google_fit_refresh_token=

# Oura Ring — cloud.ouraring.com/user/api-tokens (paste token directly)
oura_api_key=

# Withings — developer.withings.com (OAuth2)
# After creating the app: GET /api/health/oauth/authorize/withings
withings_client_id=
withings_client_secret=
withings_access_token=
withings_refresh_token=

# Garmin Connect (uses your login — requires: pip install garth)
garmin_email=
garmin_password=

# Apple Health / Samsung Health (webhook — no REST API exists on these platforms)
# iOS: install "Health Auto Export" app, point it to POST /api/health/webhook/apple
# Android/Samsung: install a compatible exporter, point to POST /api/health/webhook/samsung
health_webhook_secret=

# ── Live data APIs (all optional) ─────────────────────────────────
the_news_api=
alpha_vantage=
